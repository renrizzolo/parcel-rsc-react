{
  "name": "@renr/parcel-reporter-rsc-router",
  "version": "1.0.0-alpha.10",
  "author": "Ren Rizzolo",
  "license": "MIT",
  "description": "Parcel reporter that generates filesystem route definitions on build",
  "keywords": [
    "parcel",
    "rsc"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renrizzolo/parcel-rsc-react.git"
  },
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    "default": {
      "types": "./dist/esm/index.d.mts",
      "default": "./dist/esm/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@parcel/diagnostic": "^2.16.4",
    "@parcel/plugin": "^2.16.4",
    "dedent": "^1.7.2",
    "tinyglobby": "^0.2.16",
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "@renr/parcel-rsc-router": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
